rules_version = '2';

// Al-Wazrah family tree — Firestore security rules (open editing model).
// Paste into: Firebase console → Firestore Database → Rules → Publish.
//
// Model:
//  - Anyone can READ the tree, photos and edit history (same as the public site).
//  - Any signed-in Google account can WRITE. Every edit is attributed to the
//    account in the revisions history and can be reverted there.
//  - Only the admin can rewrite or delete history entries (and perform full
//    restores via the app's import).

service cloud.firestore {
  match /databases/{db}/documents {

    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'alhammad.md@gmail.com';
    }
    function isEditor() { return signedIn(); }

    match /tree/{doc} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /photos/{doc} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /revisions/{doc} {
      allow read: if true;
      allow create: if isEditor();
      allow update, delete: if isAdmin();
    }
  }
}
